# ============================================================
# Copia este archivo como `.env.local` y llena los valores.
# `.env.local` NUNCA se sube a GitHub (ya está en .gitignore).
# En Vercel estos mismos valores van en Settings → Environment Variables.
# ============================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # ¡secreta! solo se usa en el servidor

# --- WhatsApp Cloud API (ver GUIA-WHATSAPP.md, sección "Los 3 valores") ---
WHATSAPP_TOKEN=EAAG...              # token permanente del usuario del sistema
WHATSAPP_PHONE_NUMBER_ID=123456789  # de la pantalla API Setup
WHATSAPP_VERIFY_TOKEN=inventa-una-contraseña-aqui
